{
	"name": "stratum-ui",
	"version": "0.3.1",
	"description": "Svelte 5 UI and LayerCake charting components with a CSS custom-property design system",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/chienleng/stratum-ui.git"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"package": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./charts": {
			"types": "./dist/charts/index.d.ts",
			"svelte": "./dist/charts/index.js",
			"default": "./dist/charts/index.js"
		},
		"./charts/elements": {
			"types": "./dist/charts/elements/index.d.ts",
			"svelte": "./dist/charts/elements/index.js",
			"default": "./dist/charts/elements/index.js"
		},
		"./ui": {
			"types": "./dist/ui/index.d.ts",
			"svelte": "./dist/ui/index.js",
			"default": "./dist/ui/index.js"
		},
		"./forms": {
			"types": "./dist/forms/index.d.ts",
			"svelte": "./dist/forms/index.js",
			"default": "./dist/forms/index.js"
		},
		"./actions": {
			"types": "./dist/actions/index.d.ts",
			"default": "./dist/actions/index.js"
		},
		"./utils": {
			"types": "./dist/utils/index.d.ts",
			"default": "./dist/utils/index.js"
		},
		"./icons/*": {
			"types": "./dist/icons/*.d.ts",
			"svelte": "./dist/icons/*",
			"default": "./dist/icons/*"
		},
		"./themes/*": "./dist/themes/*"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"@types/d3-array": "^3.2.2",
		"@types/d3-color": "^3.1.3",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"bits-ui": "^2.18.1",
		"d3-array": "^3.2.4",
		"d3-color": "^3.1.0",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"date-fns": "^4.4.0",
		"esm-env": "^1.2.2",
		"layercake": "^10.0.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/dm-sans": "^5.3.0",
		"@fontsource-variable/inter": "^5.3.0",
		"@fontsource-variable/jetbrains-mono": "^5.3.0",
		"@fontsource-variable/space-grotesk": "^5.3.0",
		"@fontsource/dm-mono": "^5.3.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^22",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"publint": "^0.3.21",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"keywords": [
		"svelte",
		"sveltekit",
		"layercake",
		"charts",
		"components",
		"design-system"
	],
	"packageManager": "pnpm@11.15.1"
}
